{
  "name": "@qalaam/adapter-web",
  "version": "0.0.1",
  "description": "Qalaam — browser-as-speaker adapter. HTML5 audio + Media Session API. Per ADR-0003.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@qalaam/adapter-interface": "workspace:*",
    "@qalaam/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
