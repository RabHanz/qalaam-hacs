{
  "name": "@qalaam/adapter-interface",
  "version": "0.0.1",
  "description": "Qalaam — Speaker / Adapter contract per ADR-0003. Every device adapter (Cast, Sonos, AirPlay, Web, HA, MQTT, BT) implements this interface.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./contract-tests": {
      "types": "./dist/contract-tests.d.ts",
      "import": "./dist/contract-tests.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@qalaam/core": "workspace:*",
    "@qalaam/types-ts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
