{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qalaam.app/schemas/quran/Mushaf.schema.json",
  "title": "Mushaf",
  "description": "A specific mushaf layout — defines page boundaries and line-per-page for rendering. Sourced from QUL `mushaf_layouts` table (ADR-0002).",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "pageCount", "linesPerPage"],
  "properties": {
    "layout": { "$ref": "../common/Primitives.schema.json#/$defs/MushafLayout" },
    "name": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "ar"],
      "properties": {
        "en": { "type": "string" },
        "ar": { "type": "string" }
      }
    },
    "pageCount": { "type": "integer", "minimum": 1 },
    "linesPerPage": { "type": "integer", "minimum": 1, "maximum": 25 },
    "fontSlug": {
      "type": "string",
      "description": "Stable identifier for the rendering font (e.g., 'qpc-hafs-v2', 'indopak-16-line')."
    },
    "qulMushafId": {
      "type": ["string", "null"],
      "description": "QUL mushaf_layouts row identifier."
    }
  }
}
