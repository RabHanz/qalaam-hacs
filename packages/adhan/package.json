{
  "name": "@qalaam/adhan",
  "version": "0.0.1",
  "description": "Qalaam — adhan (prayer-time) calculator + qibla bearing + hijri calendar. Wraps Batoul Apps' adhan-js (MIT) with typed Qalaam API.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@qalaam/core": "workspace:*",
    "adhan": "^4.4.3",
    "moment-hijri": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
