# ==============================================================================
# Qalaam Production env — copy to `.env` and fill in. NEVER commit `.env`.
# ==============================================================================
# Single source of truth for the deployed URL is `DOMAIN`. Flip the URL by
# changing this one variable + the Cloudflare DNS A record. Everything else
# follows.
# ==============================================================================

# ---- domain ------------------------------------------------------------------
DOMAIN=qalaam.themarginapp.com
ACME_EMAIL=admin@themarginapp.com

# ---- runtime tuning ----------------------------------------------------------
LOG_LEVEL=info
# Set to `1` to compile the web bundle with the React Compiler. Off by
# default in production until the stability bake-in completes.
QALAAM_REACT_COMPILER=

# ---- Quran.Foundation Tier A (optional) --------------------------------------
# When set, the backend can fall back to Quran.Foundation's API for
# resources missing from the local qul.sqlite. Leave empty to run
# fully self-contained.
QF_BASE_URL=https://apis.quran.foundation
QF_OAUTH_URL=https://oauth2.quran.foundation
QF_CLIENT_ID=
QF_CLIENT_SECRET=

# ==============================================================================
# Notes — what's intentionally absent
# ==============================================================================
# - No DATABASE_URL / Postgres. Qalaam's primary store is SQLite by
#   design (ADR-0023). Self-host = single mountable file.
# - No REDIS_URL. Sessions + rate-limit live in qalaam.sqlite (auth_audit
#   sliding window survives restarts; Redis cache would not).
# - No NEXTAUTH_SECRET / GOOGLE_CLIENT_ID / etc. Qalaam ships its own
#   scrypt + cookie auth — by-design no third-party identity provider
#   between the user and their Quranic data (privacy promise per §15).
# - No STRIPE_*. H2 ships pricing UI + manual activation via the
#   support_requests table; Stripe checkout adds in a follow-up commit
#   once we're ready for real card processing.
# - No TTS / GPU env. H3/H4 voice cloning ships as a separate
#   `services/tts-worker/` container with its own compose stanza when
#   GPU host bring-up happens.
