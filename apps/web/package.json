{
  "name": "qalaam-web",
  "version": "0.0.1",
  "description": "Qalaam standalone web app — Next.js 15, React 19, Tailwind v4, RTL-aware. Per ADR-0011 (AGPL-3 SaaS).",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start --port 3000",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@qalaam/api-client-ts": "workspace:*",
    "@qalaam/core": "workspace:*",
    "@qalaam/curriculum": "workspace:*",
    "@qalaam/types-ts": "workspace:*",
    "@qalaam/ui": "workspace:*",
    "@qalaam/ui-hifdh": "workspace:*",
    "@qalaam/ui-learn": "workspace:*",
    "@qalaam/ui-quran": "workspace:*",
    "@qalaam/ui-recite": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-beta.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
