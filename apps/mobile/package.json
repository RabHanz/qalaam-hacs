{
  "name": "qalaam-mobile",
  "version": "0.0.1",
  "description": "Qalaam mobile (Expo SDK 53 + React Native + React 19). Per ADR-0013 + Phase 12. AGPL-3.",
  "license": "AGPL-3.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint app",
    "clean": "rm -rf .expo node_modules/.cache"
  },
  "dependencies": {
    "@qalaam/core": "workspace:*",
    "@qalaam/types-ts": "workspace:*",
    "expo": "~53.0.0",
    "expo-av": "~15.0.0",
    "expo-constants": "~17.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "^19.0.0",
    "react-native": "0.76.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
