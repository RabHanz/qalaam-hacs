{
  "name": "qalaam",
  "private": true,
  "version": "0.0.0",
  "description": "Qalaam — family-aware, smart-home-aware, AI-augmented Quran and Hifdh platform",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/qalaam-org/qalaam",
  "repository": {
    "type": "git",
    "url": "https://github.com/qalaam-org/qalaam.git"
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.12.0"
  },
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "packages/*",
    "apps/*",
    "integrations/*",
    "services/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint && pnpm format:check",
    "lint:fix": "turbo run lint -- --fix && pnpm format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "codegen": "turbo run codegen",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "bootstrap": "pnpm install && pnpm codegen && pnpm build",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "py:lint": "uv run ruff check .",
    "py:lint:fix": "uv run ruff check . --fix && uv run ruff format .",
    "py:typecheck": "uv run mypy .",
    "py:test": "uv run pytest",
    "py:ci": "pnpm py:lint && pnpm py:typecheck && pnpm py:test",
    "ci:all": "pnpm ci && pnpm py:ci",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "syncpack": "^13.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
