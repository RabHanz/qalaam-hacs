!.vscode/settings.shared.json
.idea/
*.swp
*.swo
.fleet/
.zed/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Generated codegen artifacts pinned via separate rules in package .gitignore ---
# (We DO commit codegen output; per-package .gitignore handles it.)

# --- Data (large; via Git LFS) ---
data/qul.sqlite
data/qul.sqlite-journal
data/quran-align/
data/audio-cache/

# --- Local dev artifacts ---
.local/
tmp/
.tmp/
*.local
.docker/
docker-compose.override.yml

# --- ML / training ---
ml/checkpoints/
ml/datasets/raw/
wandb/
mlruns/
*.ckpt
*.safetensors
*.pt
*.pth
*.onnx

# --- Testing ---
playwright-report/
test-results/
.nyc_output/

# --- Misc ---
*.pid
.history/
.changeset/*-changeset.md
!.changeset/config.json
!.changeset/README.md
.eslintcache

# Image-mushaf overlay PNGs — 63MB of KFGQPC page renders staged from
# data/qul-source/raw/unpacked/mushaf-layout-12.sqlite/6/*.png by
# scripts/data/ingest-image-mushaf-overlays.py. Re-run the ingest to
# repopulate; no need to track in git.
apps/web/public/mushaf-images/

# QUL raw data — large binary downloads, regenerated by scripts/data/scrape-qul-full.py
# Sidecar .license.json files are kept for license-tag review
data/qul-source/raw/**/*.zip
data/qul-source/raw/**/*.sqlite
data/qul-source/raw/**/*.json
!data/qul-source/raw/**/*.license.json
data/qul-source/raw/**/*.ttf
data/qul-source/raw/**/*.woff
data/qul-source/raw/**/*.woff2
data/qul-source/raw/**/*.otf
data/qul-source/raw/**/*.csv
data/qul-source/raw/**/*.db
data/qul-source/raw/**/*.tar
data/qul-source/raw/**/*.gz
data/qul-source/.cookies.txt

# QPC V4 Tajweed page fonts — 604 woff2 files (~50MB), regenerated by
# scripts/data/download-qpc-v4-fonts.sh. SHA256 pins committed at
# data/qul-source/qpc-v4-fonts.sha256.
apps/web/public/fonts/quran-tajweed-v4/*.woff2
