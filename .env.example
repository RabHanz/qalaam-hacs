# Qalaam — environment variables
# Copy to `.env` (which is gitignored) and fill in.
# NEVER commit `.env` — production secrets live in your secret manager.

# ---------- Node / general ----------
NODE_ENV=development
LOG_LEVEL=debug

# ---------- Backend ----------
PORT=4000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Supabase / Postgres) ----------
DATABASE_URL=postgresql://qalaam:qalaam@localhost:5432/qalaam_dev
DIRECT_DATABASE_URL=postgresql://qalaam:qalaam@localhost:5432/qalaam_dev

# ---------- Cache (Redis) ----------
REDIS_URL=redis://localhost:6379

# ---------- Cloudflare R2 (audio storage) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=qalaam-audio
R2_PUBLIC_URL=

# ---------- Auth (Supabase) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Quran Foundation API ----------
QF_CLIENT_ID=
QF_CLIENT_SECRET=
QF_BASE_URL=https://apis.quran.foundation
QF_OAUTH_URL=https://oauth2.quran.foundation
# Pre-prod variants:
# QF_BASE_URL=https://apis-prelive.quran.foundation
# QF_OAUTH_URL=https://prelive-oauth2.quran.foundation

# ---------- ElevenLabs (TTS MVP, ADR-0014) ----------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_QALAAM_HOUSE=

# ---------- Home Assistant adapter ----------
HA_BASE_URL=http://homeassistant.local:8123
HA_LONG_LIVED_TOKEN=

# ---------- Stripe (billing) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ---------- Observability ----------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------- Device-bridge (Python sidecar) ----------
DEVICE_BRIDGE_GRPC_URL=localhost:50051

# ---------- ASR worker ----------
ASR_WORKER_URL=http://localhost:5001
ASR_MODEL_ID=tarteel-ai/whisper-base-ar-quran

# ---------- TTS worker (post v1.5 self-host path) ----------
TTS_WORKER_URL=http://localhost:5002
TTS_MODEL_ID=qalaam/habibi-quran
